# Secrets for agent-activity-report workflow.
# All secrets use $shared references resolved from <repo-root>/.secrets/.
# Run: tntc secrets init --shared (from the repo root)

github: $shared.github    # GitHub token for API access
openai: $shared.openai    # OpenAI API key
slack: $shared.slack       # Slack webhook URL
azure: $shared.azure       # Azure Blob Storage SAS token
